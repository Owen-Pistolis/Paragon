{
    "Web Login and Data Entry": {
        "name": "Web Login and Data Entry",
        "actions": [
            {
                "type": "open_selenium",
                "browser": "chrome",
                "headless": false,
                "meta_information": {
                    "sequence_order": 1,
                    "description": "Open browser"
                }
            },
            {
                "type": "url_navigation",
                "url": "https://demoqa.com/login",
                "meta_information": {
                    "sequence_order": 2,
                    "description": "Navigate to login page"
                }
            },
            {
                "type": "element_interact",
                "selector": "//input[@id='userName']",
                "by": "xpath",
                "action": "input",
                "credential_name": "testycombinator",
                "credential_field": "username",
                "meta_information": {
                    "sequence_order": 3,
                    "description": "Enter username from credentials"
                },
                "value": "test"
            },
            {
                "type": "element_interact",
                "selector": "//input[@id='password']",
                "by": "xpath",
                "action": "input",
                "credential_name": "testycombinator",
                "credential_field": "password",
                "meta_information": {
                    "sequence_order": 4,
                    "description": "Enter password from credentials"
                },
                "value": "test"
            },
            {
                "type": "element_interact",
                "selector": "//button[@id='login']",
                "by": "xpath",
                "action": "click",
                "meta_information": {
                    "sequence_order": 5,
                    "description": "Click login button"
                }
            },
            {
                "type": "close_selenium",
                "meta_information": {
                    "sequence_order": 6,
                    "description": "Close browser"
                }
            }
        ]
    },
    "Mixed Desktop-Web Automation": {
        "name": "Mixed Desktop-Web Automation",
        "actions": [
            {
                "type": "open_application",
                "application_path": "notepad.exe",
                "meta_information": {
                    "sequence_order": 1,
                    "description": "Open Notepad"
                }
            },
            {
                "type": "typing_sequence",
                "text": "Research Notes:\n",
                "typing_speed": 0.1,
                "meta_information": {
                    "sequence_order": 2,
                    "description": "Type header"
                }
            },
            {
                "type": "open_selenium",
                "browser": "chrome",
                "headless": false,
                "meta_information": {
                    "sequence_order": 3,
                    "description": "Open browser"
                }
            },
            {
                "type": "url_navigation",
                "url": "https://www.wikipedia.org",
                "meta_information": {
                    "sequence_order": 4,
                    "description": "Navigate to Wikipedia"
                }
            },
            {
                "type": "element_interact",
                "selector": "//input[@id='searchInput']",
                "by": "xpath",
                "action": "input",
                "value": "Automation",
                "meta_information": {
                    "sequence_order": 5,
                    "description": "Enter search term"
                }
            },
            {
                "type": "key_combination",
                "keys": [
                    "alt",
                    "tab"
                ],
                "meta_information": {
                    "sequence_order": 6,
                    "description": "Switch to Notepad"
                }
            },
            {
                "type": "typing_sequence",
                "text": "Research completed.",
                "typing_speed": 0.1,
                "meta_information": {
                    "sequence_order": 7,
                    "description": "Type conclusion"
                }
            },
            {
                "type": "close_selenium",
                "meta_information": {
                    "sequence_order": 8,
                    "description": "Close browser"
                }
            }
        ]
    },
